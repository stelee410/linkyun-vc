# =============================================================================
# Linkyun 前端环境配置模板
# 复制此文件为 .env.local 并填写您的配置
# =============================================================================

# API 基地址（可选，默认 https://linkyun.co）
VITE_API_BASE_URL="https://linkyun.co"

# 工作空间配置
VITE_WORKSPACE_CODE="your-workspace-code"
VITE_WORKSPACE_JOIN_CODE="your-join-code"

# Agent 配置
# 这些 Agent 需要在创作者界面创建后，将 code 填写在此处
VITE_SYSTEM_AGENT_CODE="your-system-agent"
VITE_SYSTEM_ASSISTANT_AGENT_CODE="your-assistant-agent"
VITE_SYSTEM_SERVICE_AGENT_CODE="your-service-agent"

# 主题配置
# 可选值: legalwise (律小乖) | vc (凌云资本)
VITE_SITE_THEME="legalwise"

# 注册邀请码（用户注册时需要输入，需要先在服务端添加）
VITE_REGISTER_INVITATION_CODE="your-invitation-code"
